{
  "extends": ["stylelint-config-standard-scss"],
  "plugins": ["stylelint-scss"],
  "customSyntax": "postcss-scss",
  "rules": {
    "scss/no-global-function-names": true,
    "scss/dollar-variable-pattern": "^[a-z][a-z0-9-]*$",
    "scss/at-mixin-pattern": "^[a-z][a-z0-9-]*$",
    "scss/at-function-pattern": "^[a-z][a-z0-9-]*$",
    "scss/at-rule-no-unknown": [true, {
      "ignoreAtRules": ["tailwind", "apply", "variants", "responsive", "screen"]
    }],

    "declaration-no-important": true,
    "selector-pseudo-class-no-unknown": [true, {
      "ignorePseudoClasses": ["global", "local"]
    }],
    "function-disallowed-list": ["lighten", "darken", "saturate", "desaturate", "adjust-hue", "fade-in", "fade-out", "opacify", "transparentize"],
    "property-disallowed-list": [],

    "scss/at-use-no-unnamespaced": null,
    "scss/at-extend-no-missing-placeholder": null,
    "scss/load-no-partial-leading-underscore": null,
    "scss/double-slash-comment-empty-line-before": null,
    "scss/dollar-variable-empty-line-before": null,
    "scss/dollar-variable-colon-space-after": null,
    "scss/at-mixin-argumentless-call-parentheses": null,
    "scss/operator-no-newline-after": null,
    "scss/comment-no-empty": null,

    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "declaration-empty-line-before": null,
    "at-rule-empty-line-before": null,
    "rule-empty-line-before": null,
    "comment-empty-line-before": null,
    "no-empty-source": null,
    "alpha-value-notation": null,
    "color-function-notation": null,
    "color-function-alias-notation": null,
    "value-keyword-case": null,
    "media-feature-range-notation": null,
    "import-notation": null,
    "at-rule-no-unknown": null,
    "declaration-block-single-line-max-declarations": null,
    "keyframes-name-pattern": null,
    "custom-property-pattern": null,
    "shorthand-property-no-redundant-values": null,
    "declaration-block-no-redundant-longhand-properties": null,
    "number-max-precision": null,
    "length-zero-no-unit": null,
    "color-hex-length": null,
    "property-no-vendor-prefix": null,
    "property-no-deprecated": null
  },
  "overrides": [
    {
      "files": ["src/**/*.module.scss"],
      "rules": {
        "color-no-hex": true
      }
    }
  ],
  "ignoreFiles": [
    "node_modules/**",
    "dist/**",
    "coverage/**",
    ".webpack_cache/**"
  ]
}
