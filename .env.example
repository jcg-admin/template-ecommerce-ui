# ═══════════════════════════════════════════════════════════════
# PracticaYoruba UI — Variables de entorno
# Copiar a .env.local para desarrollo local
# NUNCA commitear .env.local ni .env.production
# ═══════════════════════════════════════════════════════════════

# URL del backend Django DRF
API_URL=http://localhost:8000

# Feature flags — 'mock' usa datos locales, 'real' llama al backend
AUTH_SOURCE=mock
CATALOG_SOURCE=mock
CART_SOURCE=mock
PAYMENTS_SOURCE=mock

# MercadoPago (solo en producción)
# MP_PUBLIC_KEY=APP_USR-...

# PayPal (solo en producción)
# PAYPAL_CLIENT_ID=...

# Analytics (opcional)
# GA_TRACKING_ID=G-...
