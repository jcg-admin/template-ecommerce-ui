{
  "name": "e-comerce-ui",
  "version": "1.0.0",
  "description": "e-comerce-ui — Generic e-commerce frontend template. React 19 + Redux Toolkit + Webpack 5.",
  "main": "src/index.jsx",
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "src/styles/**/*",
    "src/mocks/**/*"
  ],
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:analyze": "ANALYZE=true webpack --mode production",
    "build:watch": "webpack --mode production --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:style": "stylelint \"src/**/*.scss\"",
    "lint:style:fix": "stylelint \"src/**/*.scss\" --fix",
    "lint:scss-compile": "node scripts/check-scss.mjs",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,scss}",
    "prepare": "husky"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@tanstack/react-query": "^5.100.5",
    "dompurify": "^3.4.1",
    "framer-motion": "^12.38.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.0.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.15.0",
    "reselect": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.3.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "html-webpack-plugin": "^5.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "mini-css-extract-plugin": "^2.7.0",
    "postcss-loader": "^7.3.0",
    "postcss-scss": "^4.0.9",
    "redux-mock-store": "^1.5.5",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "stylelint": "^17.11.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.1.1",
    "terser-webpack-plugin": "^5.3.9",
    "webpack": "^5.88.0",
    "webpack-bundle-analyzer": "^5.3.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.3"
  },
  "browserslist": {
    "production": [
      "> 0.5%",
      "last 2 versions",
      "not dead"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
