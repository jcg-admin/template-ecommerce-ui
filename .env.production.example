# =============================================================================
# .env.production.example — PracticaYoruba-ui
# =============================================================================
# Plantilla de variables de entorno para el build de producción del UI.
#
# Uso:
#   cp .env.production.example .env.production
#   # Editar .env.production con los valores reales del servidor
#   npm run build
#
# El archivo .env.production está en .gitignore — nunca lo subas al repo.
# El archivo .env.production.example SÍ está en el repo (es la plantilla).
#
# Cómo funciona:
#   Webpack lee .env.production cuando NODE_ENV=production.
#   La variable API_URL se inyecta en el bundle via DefinePlugin:
#     process.env.API_URL → 'https://practicayoruba.mx'
#   El bundle resultante tiene la URL hardcodeada — no es configurable
#   en runtime, solo en el momento del build.
# =============================================================================

# URL base del API Django en producción.
# Debe apuntar al dominio donde Apache sirve PracticaYoruba-server.
# Sin trailing slash.
API_URL=https://practicayoruba.mx
